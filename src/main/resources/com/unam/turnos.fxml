<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.unam.controller.TurnosController">
    <top>
        <HBox spacing="10" styleClass="toolbar" alignment="CENTER_LEFT">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <Button text="&lt; Menú" onAction="#volverAlMenu"/>
            <Label text="Gestión de Turnos" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="Fecha:"/>
            <DatePicker fx:id="selectorFecha"/>
            <Button text="Ver turnos" onAction="#cargarTurnosDeFecha"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="8">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <TableView fx:id="tablaTurnos" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colHora" text="Hora" prefWidth="140"/>
                    <TableColumn fx:id="colMascota" text="Mascota" prefWidth="130"/>
                    <TableColumn fx:id="colVeterinario" text="Veterinario" prefWidth="160"/>
                    <TableColumn fx:id="colServicios" text="Servicios" prefWidth="220"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"/>
                    <TableColumn fx:id="colPrecio" text="Precio" prefWidth="90"/>
                </columns>
            </TableView>
            <HBox spacing="8">
                <Button text="Nuevo Turno" onAction="#nuevoTurno"/>
                <Button text="Confirmar" onAction="#confirmarTurno"/>
                <Button text="Atender" onAction="#atenderTurno"/>
                <Button text="Cancelar Turno" onAction="#cancelarTurno"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
