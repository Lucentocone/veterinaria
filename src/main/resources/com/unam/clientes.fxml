<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.unam.controller.ClientesController">
    <top>
        <HBox spacing="10" styleClass="toolbar">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <Button text="&lt; Menú" onAction="#volverAlMenu"/>
            <Label text="Clientes y Mascotas" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.55">
            <VBox spacing="8">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <HBox spacing="8">
                    <TextField fx:id="campoBusquedaCliente" promptText="Buscar por nombre, apellido o DNI..." HBox.hgrow="ALWAYS"/>
                    <Button text="Buscar" onAction="#buscarClientes"/>
                </HBox>
                <TableView fx:id="tablaClientes" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colDni" text="DNI" prefWidth="90"/>
                        <TableColumn fx:id="colNombre" text="Nombre" prefWidth="120"/>
                        <TableColumn fx:id="colApellido" text="Apellido" prefWidth="120"/>
                        <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="100"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="150"/>
                    </columns>
                </TableView>
                <HBox spacing="8">
                    <Button text="Nuevo Cliente" onAction="#nuevoCliente"/>
                    <Button text="Editar Cliente" onAction="#editarCliente"/>
                </HBox>
            </VBox>
            <VBox spacing="8">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <Label text="Mascotas del cliente seleccionado" style="-fx-font-weight: bold;"/>
                <TableView fx:id="tablaMascotas" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colFicha" text="Ficha" prefWidth="60"/>
                        <TableColumn fx:id="colNombreMascota" text="Nombre" prefWidth="110"/>
                        <TableColumn fx:id="colEspecie" text="Especie" prefWidth="90"/>
                        <TableColumn fx:id="colRaza" text="Raza" prefWidth="100"/>
                        <TableColumn fx:id="colEdad" text="Edad" prefWidth="60"/>
                        <TableColumn fx:id="colActiva" text="Activa" prefWidth="60"/>
                    </columns>
                </TableView>
                <HBox spacing="8">
                    <Button text="Nueva Mascota" onAction="#nuevaMascota"/>
                    <Button text="Editar Mascota" onAction="#editarMascota"/>
                    <Button text="Dar de Baja / Reactivar" onAction="#toggleBajaMascota"/>
                </HBox>
                <HBox spacing="8">
                    <Button text="Ver Historial Médico" onAction="#verHistorial"/>
                    <Button text="Ver Turnos" onAction="#verTurnos"/>
                </HBox>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
